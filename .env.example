# ==========================================================================
# AcceptGPT - biến môi trường mẫu.
# Copy sang `.env` rồi điền giá trị thật. KHÔNG commit file `.env`.
# ==========================================================================

# --- Webhook server -------------------------------------------------------
# Chỉ nên bind vào localhost và đặt sau Caddy/Nginx reverse proxy.
HOST=127.0.0.1
PORT=8080
WEBHOOK_PATH=/webhook

# Secret bắt buộc gửi kèm trong header `x-webhook-secret`.
# Để trống nếu muốn tắt (KHÔNG khuyến khích trên production).
WEBHOOK_SECRET=change-me

# --- ChatGPT workspace ----------------------------------------------------
# URL trang quản lý thành viên (Members) của workspace — tab "Pending requests".
MEMBERS_URL=https://chatgpt.com/admin/members?tab=requests

# --- Telegram -------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# --- Browser --------------------------------------------------------------
# Thư mục persistent profile của Chromium (giữ cookie/session).
BROWSER_PROFILE_DIR=./data/browser-profile

# headless=false để dùng cùng Xvfb trên VPS (đăng nhập thủ công qua noVNC).
HEADLESS=false

# Đường dẫn Chromium tùy chọn. Để trống dùng Chromium do Playwright cài.
CHROMIUM_EXECUTABLE_PATH=

# --- Thư mục output -------------------------------------------------------
LOGS_DIR=./logs
SCREENSHOTS_DIR=./screenshots

# --- Tinh chỉnh timeout / retry (ms trừ khi ghi chú khác) -----------------
NAV_TIMEOUT_MS=45000
ACTION_TIMEOUT_MS=15000
PAGE_LOAD_RETRIES=3
TELEGRAM_RETRIES=3

# Mức log: debug | info | warn | error
LOG_LEVEL=info

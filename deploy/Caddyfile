# Caddyfile cho AcceptGPT — reverse proxy + tự động HTTPS (Let's Encrypt).
#
# Web CDK dùng domain gốc; webhook cũ giữ subdomain riêng.
#
# Caddy tự xin & gia hạn chứng chỉ TLS khi khởi động (cần mở cổng 80 + 443 và
# DNS đã phân giải đúng về VPS). Backend AcceptGPT vẫn chỉ nghe 127.0.0.1:8080.

nguyenhoanganh.dev {
    encode zstd gzip

    # Web nạp CDK và admin; không expose webhook ở domain này.
    @allowed {
        path / /api/redeem /admin /api/admin/* /health
    }
    handle @allowed {
        reverse_proxy 127.0.0.1:8080
    }
    handle {
        respond "Not found" 404
    }

}

accept.nguyenhoanganh.dev {
    encode zstd gzip

    # Webhook hiện có giữ nguyên subdomain này.
    @allowed path /webhook /health
    handle @allowed {
        reverse_proxy 127.0.0.1:8080
    }
    handle {
        respond "Not found" 404
    }
}
